{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "default_agent": "build",
  "autoupdate": true,

  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "git commit *": "deny",
      "git push *": "deny",
      "rm -rf *": "ask"
    },
    "edit": "allow",
    "webfetch": "allow",
    "skill": "allow"
  },

  "mcp": {
    "aem-cs-sdk": {
      "type": "remote",
      "url": "http://localhost:4502/bin/mcp",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Basic YWRtaW46YWRtaW4="
      }
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--remote-debugging-port", "9222"],
      "enabled": true
    }
  }
}
